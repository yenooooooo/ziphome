# ============================================================
# 집지킴이 (ZipJikimi) — 환경변수 템플릿
# ============================================================
# 실제 키는 .env.local 에 복사 후 입력 (Git 추적 X)
# 클라이언트 노출: NEXT_PUBLIC_ 접두사만 사용
# 서버 전용: API Routes 에서만 접근 — 절대 client 컴포넌트에서 import 금지
# ============================================================

# ---------- Supabase (기존 프로젝트 공유 — 테이블 접두사 zj_) ----------
ZJ_SUPABASE_URL=
ZJ_SUPABASE_ANON_KEY=
ZJ_SUPABASE_SERVICE_ROLE_KEY=
# 클라이언트에서도 필요하면 NEXT_PUBLIC_ 버전도 추가
NEXT_PUBLIC_ZJ_SUPABASE_URL=
NEXT_PUBLIC_ZJ_SUPABASE_ANON_KEY=

# ---------- 공공데이터포털 (국토교통부/국세청/경찰청/행안부) ----------
# 발급: https://www.data.go.kr/ → 회원가입 → 마이페이지 → 일반 인증키(Decoding)
# 1개 키로 여러 API 사용 가능 (각 API 개별 활용신청 필요)
ZJ_DATA_GO_KR_API_KEY=

# ---------- 카카오 (지도 + 로컬) ----------
# 발급: https://developers.kakao.com/ → 애플리케이션 추가
# JavaScript 키: 도메인 제한 필수 (localhost + 배포 도메인만 허용)
NEXT_PUBLIC_ZJ_KAKAO_MAP_KEY=
# REST API 키: 서버 사이드에서만 사용 (주소↔좌표 변환, 장소 검색)
ZJ_KAKAO_REST_KEY=

# ---------- 한국은행 ECOS (기준금리 — 전월세 전환율 계산용) ----------
# 발급: https://ecos.bok.or.kr/api/
ZJ_ECOS_API_KEY=

# ---------- 한국부동산원 R-ONE (전월세 전환율 통계) ----------
# 발급: https://www.reb.or.kr/r-one/portal/openapi/
ZJ_REB_API_KEY=

# ---------- VWorld (F11 용도지역 조회 — 무료) ----------
# 발급: https://www.vworld.kr/ → 회원가입 → [오픈API] → 인증키 신청
# 도메인 등록 필수 (localhost:3000 / 배포 도메인 둘 다)
ZJ_VWORLD_API_KEY=

# ---------- 에이픽 Apick (등기부등본 열람 — 유료, 900원/건) ----------
# 발급: https://apick.app/ → 회원가입 → 포인트 충전
# ⚠️ 개발 중 절대 남용 금지 — mock 데이터 우선 사용
ZJ_APICK_API_KEY=

# ---------- Anthropic Claude (계약서 특약 자동 생성) ----------
# 발급: https://console.anthropic.com/
ZJ_ANTHROPIC_API_KEY=
